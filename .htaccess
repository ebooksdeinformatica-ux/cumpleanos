# Configuración básica para GitHub Pages

# Redirigir www a la versión sin www
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.paracumpleanos\.com$ [NC]
RewriteRule ^(.*)$ https://paracumpleanos.com/$1 [R=301,L]

# Cache para recursos estáticos
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType image/webp A2592000
ExpiresByType image/jpg A2592000
ExpiresByType image/jpeg A2592000
ExpiresByType image/png A2592000
ExpiresByType image/gif A2592000
ExpiresByType text/css A2592000
ExpiresByType text/javascript A2592000
ExpiresByType application/javascript A2592000
</IfModule>

# Compresión Gzip
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html
AddOutputFilterByType DEFLATE text/css
AddOutputFilterByType DEFLATE text/javascript
AddOutputFilterByType DEFLATE application/javascript
AddOutputFilterByType DEFLATE image/webp
</IfModule>

# Tipo MIME para WebP
<IfModule mod_mime.c>
AddType image/webp .webp
</IfModule>

# Redirigir a HTTPS (GitHub Pages ya lo hace automáticamente)

# Error 404 personalizado
ErrorDocument 404 /404.html